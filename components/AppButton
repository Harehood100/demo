import { TouchableOpacity, Text, StyleSheet } from 'react-native'

/**
 * AppButton
 *
 * variant:
 *   'outline'  — white bg, purple border + purple text  (default Continue)
 *   'solid'    — navy bg, white text                    (Save Appointment / Confirm Code)
 *   'disabled' — muted lavender bg, white text          (Save Appointment disabled state)
 */
export default function AppButton({ label, onPress, variant = 'outline', style }) {
    return (
        <TouchableOpacity
            onPress={onPress}
            activeOpacity={0.8}
            disabled={variant === 'disabled'}
            style={[styles.base, styles[variant], style]}
        >
            <Text style={[styles.label, styles[`${variant}Label`]]}>{label}</Text>
        </TouchableOpacity>
    )
}

const styles = StyleSheet.create({
    base: {
        width: '100%',
        height: 56,
        borderRadius: 30,
        justifyContent: 'center',
        alignItems: 'center',
    },

    // Outline (default Continue button)
    outline: {
        backgroundColor: '#FFFFFF',
        borderWidth: 1.5,
        borderColor: '#3D3F8F',
    },
    outlineLabel: {
        color: '#3D3F8F',
        fontSize: 18,
        fontWeight: '600',
    },

    // Solid (Save Appointment, Confirm Code, Generate Code)
    solid: {
        backgroundColor: '#2D3178',
    },
    solidLabel: {
        color: '#FFFFFF',
        fontSize: 18,
        fontWeight: 'bold',
    },

    // Disabled (Save Appointment disabled state)
    disabled: {
        backgroundColor: '#8E91C4',
    },
    disabledLabel: {
        color: '#FFFFFF',
        fontSize: 18,
        fontWeight: 'bold',
    },

    label: {},
})
